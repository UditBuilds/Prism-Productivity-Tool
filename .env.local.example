# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Groq — https://console.groq.com/keys (free, no credit card)
GROQ_API_KEY=your_groq_api_key

# Public base URL of the deployed app — used for password-reset redirect links.
# Locally this can be omitted (falls back to window.location.origin).
NEXT_PUBLIC_APP_URL=https://your-vercel-url.vercel.app

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:your@email.com
# Shared secret guarding /api/push/due (the cron endpoint). Generate any random string.
CRON_SECRET=a_random_secret_string_you_generate

# Supadata — https://supadata.ai (optional; powers YouTube → flashcards).
# Without it, the YouTube analyzer returns an honest "not configured" error.
SUPADATA_API_KEY=your_supadata_api_key
